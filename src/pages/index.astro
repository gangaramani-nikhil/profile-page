---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { site, pillars, about } from '../data/site';
import { projects } from '../data/projects';
---

<Base title={`${site.name} — AI Engineering for Financial Markets`}>
  <!-- Hero (spec §3.1) -->
  <section class="hero">
    <div class="shell">
      <p class="kicker">{site.name} · {site.location}</p>
      <h1>{site.headline}</h1>
      <p class="subhead">{site.subhead}</p>
      <p class="cta">
        <a class="btn btn--primary" href="#work">See the work</a>
        <a class="btn btn--ghost" href={site.resumePath} download>Résumé (PDF)</a>
      </p>
    </div>
  </section>

  <!-- Work -->
  <section id="work" class="section">
    <div class="shell">
      <div class="section-head">
        <span class="kicker">01</span>
        <h2>Work</h2>
      </div>
      <div>
        {projects.map((p, i) => <ProjectCard project={p} index={i} />)}
      </div>
    </div>
  </section>

  <!-- Skills as the four JD pillars (spec §1/§3.4) -->
  <section id="skills" class="section">
    <div class="shell">
      <div class="section-head">
        <span class="kicker">02</span>
        <h2>Skills</h2>
      </div>
      <div class="pillar-grid">
        {pillars.map((pillar) => (
          <div class="pillar">
            <h3 class="mono">{pillar.label}</h3>
            <ul>
              {pillar.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About (spec §3.5) -->
  <section id="about" class="section">
    <div class="shell">
      <div class="section-head">
        <span class="kicker">03</span>
        <h2>About</h2>
      </div>
      <div class="about">
        {about.map((para) => <p>{para}</p>)}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section">
    <div class="shell">
      <div class="section-head">
        <span class="kicker">04</span>
        <h2>Contact</h2>
      </div>
      <p class="contact-line">
        The fastest route is email:
        <a href={`mailto:${site.email}`} class="mono">{site.email}</a>
      </p>
      <p class="contact-sub mono dim">
        Also: <a href={site.github} target="_blank" rel="noreferrer">GitHub</a>
        {site.linkedin && (
          <>
            {' · '}
            <a href={site.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
          </>
        )}
      </p>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 6.5rem 0 5rem;
  }
  .hero h1 {
    font-size: clamp(2.1rem, 5.5vw, 3.2rem);
    max-width: 18ch;
    margin: 1rem 0 1.25rem;
  }
  .subhead {
    max-width: 58ch;
    font-size: 1.08rem;
    color: var(--ink-2);
    margin-bottom: 2.25rem;
  }
  .cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
  .pillar-grid {
    display: grid;
    gap: 2.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 700px) {
    .pillar-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .pillar h3 {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-ink);
    border-bottom: 1px solid var(--hairline);
    padding-bottom: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .pillar ul {
    list-style: none;
  }
  .pillar li {
    font-size: 0.92rem;
    color: var(--ink-2);
    padding: 0.3rem 0;
  }
  .about p {
    max-width: var(--prose);
    margin-bottom: 1.1rem;
  }
  .contact-line {
    font-size: 1.05rem;
  }
  .contact-line a {
    margin-left: 0.4rem;
  }
  .contact-sub {
    margin-top: 0.75rem;
    font-size: 0.8rem;
  }
</style>
